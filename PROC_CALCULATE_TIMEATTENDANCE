								--print '@C_ST_TIME : ' + CAST(@C_ST_TIME AS CHAR)

								-- 퇴근시간 9시 이후는 그룹웨어 신청건만 적용하므로 저녁9시까지만 적용(김문성 사원 답변)
								IF @C_CLOSE_TIME > 1260
									BEGIN
