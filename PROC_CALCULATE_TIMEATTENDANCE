									END
								ELSE IF @C_CLOSE_TIME < 540
									BEGIN
										SELECT @C_ET_TIME = 1260
									END
								ELSE
									BEGIN
										SELECT @C_ET_TIME = @C_CLOSE_TIME
									END
								--print '@C_ET_TIME : ' + CAST(@C_ET_TIME AS CHAR)
			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
								-- 18 ~ 21시 근무(2018.08.21 / 김문성 사원 요청)
								--print '@18시 휴게시간을 위한 정상근무시간 계산 : ' + CAST(@C_ET_TIME - @C_ST_TIME AS CHAR)

								IF @C_ST_TIME >= (600 - @C_ADD_TIME)
									BEGIN
										--print '10시 이후 출근('+  RTRIM(CAST(@C_ET_TIME - (@C_ST_TIME + 540) AS CHAR)) + ')'
										IF @C_NIGHT_TIME >= 120
											BEGIN
												SELECT @C_BREAK_TIME_18 = 60
											END
										ELSE
											BEGIN
												SELECT @C_BREAK_TIME_18 = 0
											END
									END
								ELSE
									BEGIN
			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
										--print '10시 이전 출근('+  RTRIM(CAST(@C_ET_TIME - (@C_ST_TIME + 540) AS CHAR)) + ')'
										IF @C_NIGHT_TIME >= 120
											BEGIN
												SELECT @C_BREAK_TIME_18 = 60
											END
										ELSE
											BEGIN
												SELECT @C_BREAK_TIME_18 = 0
											END

			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
									END
								--print '@C_BREAK_TIME_18_NEW : ' + CAST(@C_BREAK_TIME_18 AS CHAR)

							

			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
								-- 휴게 시간 변경
								IF @C_ST_TIME >= (600 + @C_ADD_TIME)
									BEGIN
										IF @C_ALLNIGHT_TIME >= 240
											BEGIN
												IF @C_ALLNIGHT_TIME  - 240 < 60
													SELECT @C_BREAK_TIME_01 = @C_ALLNIGHT_TIME - 240
												ELSE
													SELECT @C_BREAK_TIME_01 = 60
											END
									END
								ELSE 
									IF @C_ALLNIGHT_TIME >= 180
										BEGIN
											IF @C_ALLNIGHT_TIME - 180 - (60 - @C_AM) < 0
												SELECT @C_BREAK_TIME_01 = 0
											ELSE IF	@C_ALLNIGHT_TIME - 180 - (60 - @C_AM) < 60
												SELECT @C_BREAK_TIME_01 = @C_ALLNIGHT_TIME - 180 - (60 - @C_AM) 
											ELSE
												SELECT @C_BREAK_TIME_01 = 60
										END
								--print '@C_BREAK_TIME_01 : ' + CAST(@C_BREAK_TIME_01 AS CHAR)

			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
								PRINT CONCAT('@C_BREAK_TIME_12 : ', @C_BREAK_TIME_12 , '@C_BREAK_TIME_18 : ',@C_BREAK_TIME_18 ,'@C_BREAK_TIME_01 : ', @C_BREAK_TIME_01,'@C_BREAK_TIME_06 : ', @C_BREAK_TIME_06)
								-- 휴게시간 합계
								SELECT @C_BREAK_TIME = @C_BREAK_TIME_12 + @C_BREAK_TIME_18 + @C_BREAK_TIME_01 + @C_BREAK_TIME_06

					
								-- 2019.06.21 추가(김문성 요청)
