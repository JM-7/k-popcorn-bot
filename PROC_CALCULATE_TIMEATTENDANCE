										UPDATE HR_TIMEATTENDANCE
											SET 
											 C_NORMAL_TIME = IIF(@C_NORMAL_TIME < 0, 0, @C_NORMAL_TIME)
											,C_NIGHT_TIME = @C_NIGHT_TIME
