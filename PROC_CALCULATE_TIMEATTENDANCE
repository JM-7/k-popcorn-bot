													BEGIN			
														IF (@C_CLOSE_TIME - @C_START_TIME) - ((@C_CLOSE_TIME - @C_START_TIME)/300)*300 > 300
															BEGIN
																SELECT @C_BREAK_TIME = ((@C_CLOSE_TIME - @C_START_TIME) - ((@C_CLOSE_TIME - @C_START_TIME)/300)*300)%240

																SELECT @C_BREAK_TIME = @C_BREAK_TIME + ((@C_CLOSE_TIME - @C_START_TIME)/300)*60
															END	
														ELSE
															BEGIN
																SELECT @C_BREAK_TIME = ((@C_CLOSE_TIME - @C_START_TIME)/300)*60
															END
						
														--PRINT '휴일111'
														SELECT @C_NORMAL_TIME = (@C_CLOSE_TIME - @C_START_TIME) - @C_BREAK_TIME
						
													END
												ELSE
													BEGIN
													
														SET @C_CLOSE_TIME = 1440 + @C_CLOSE_TIME
														
														--PRINT CONCAT('@C_CLOSE_TIME : ',@C_CLOSE_TIME,' @C_CLOSE_TIME : ', @C_START_TIME)

														IF (@C_CLOSE_TIME - @C_START_TIME) - ((@C_CLOSE_TIME - @C_START_TIME)/300)*300 > 240
															BEGIN
