			-- 2020.11.03 선택적근로시간제 휴게시간 기준 수정 - keonhuilee
									--		END

								--print '@C_ALLNIGHT_TIME : ' + CAST(@C_ALLNIGHT_TIME AS CHAR)
											
								-- 점심 휴게시간(12~13)은 RAW 출퇴근과의 교집합으로 정확히 산정
								DECLARE @LUNCH_OVERLAP INT =
									CASE
									  WHEN @RAW_C_START_TIME IS NULL OR @RAW_C_CLOSE_TIME IS NULL THEN 0
									  ELSE
										CASE
										  WHEN (CASE WHEN @RAW_C_CLOSE_TIME < 780 THEN @RAW_C_CLOSE_TIME ELSE 780 END) >
											   (CASE WHEN @RAW_C_START_TIME > 720 THEN @RAW_C_START_TIME ELSE 720 END)
										  THEN (CASE WHEN @RAW_C_CLOSE_TIME < 780 THEN @RAW_C_CLOSE_TIME ELSE 780 END)
											   - (CASE WHEN @RAW_C_START_TIME > 720 THEN @RAW_C_START_TIME ELSE 720 END)
										  ELSE 0
										END
									END;
								SET @C_BREAK_TIME_12 = @LUNCH_OVERLAP; -- 0~60분 범위

								--print '@C_BREAK_TIME_12 : ' + CAST(@C_BREAK_TIME_12 AS CHAR)

								-- 출근시간 9시 이전일 경우 9시 출근으로 산정(김문성 사원 답변)
