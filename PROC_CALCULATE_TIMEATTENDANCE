

ALTER PROCEDURE [dbo].[PROC_CALCULATE_TIMEATTENDANCE]
    @P_EMP_ID INT,            -- 대상 시스템 사번
    @P_WORK_DT VARCHAR(8)   -- 대상 근무일
AS
BEGIN TRY
    SET NOCOUNT ON;

    -- 일반 근무시간 계산용 변수
    DECLARE @PERF_CD VARCHAR(8);        -- 근태 코드
    DECLARE @START_TIME INT;            -- 출근 시간 (분 단위 HHMM -> 분)
    DECLARE @CLOSE_TIME INT;            -- 퇴근 시간 (분 단위 HHMM -> 분)
    DECLARE @LATE_TIME INT;             -- 지각 시간 (분)
    DECLARE @EARLY_TIME INT;            -- 조퇴 시간 (분)
    DECLARE @OUT_TIME INT;              -- 외출 시간 (분) - 원본 트리거에서 사용되지 않았으나 선언은 유지
    DECLARE @NORMAL_TIME INT;           -- 정상 근무 시간 (분)
    DECLARE @NIGHT_TIME INT;            -- 야간 근무 시간 (분) (21:00-24:00)
    DECLARE @MIDNIGHT_TIME INT;         -- 심야 근무 시간 (분) (00:00-04:00) - 원본 트리거 기준 명칭, 실제로는 00:00-04:00
    DECLARE @ALLNIG_TIME INT;           -- 연장 근무 시간 (분) (18:00-21:00) - 원본 트리거 기준 명칭, 실제로는 18:00-21:00 연장
    DECLARE @DKID INT;                  -- 시스템 사번 (내부 사용)
    DECLARE @WORK_DT VARCHAR(8);        -- 근무일 (내부 사용)
    DECLARE @WORK_TYPE VARCHAR(3);      -- 근무 유형 (W: 평일, H: 휴일 등)
    DECLARE @UP_OPID VARCHAR(8);        -- 최종 수정자 ID

    -- 선택근무제 필요 변수
    DECLARE @C_START_TIME INT;          -- 선택근무제 출근 시간 (실제 출퇴근 시간 혹은 그룹웨어 신청 시간)
    DECLARE @C_CLOSE_TIME INT;          -- 선택근무제 퇴근 시간 (실제 출퇴근 시간 혹은 그룹웨어 신청 시간)
    DECLARE @GW_START_TIME INT;         -- 그룹웨어 연장 신청 출근 시간
    DECLARE @GW_CLOSE_TIME INT;         -- 그룹웨어 연장 신청 퇴근 시간
    DECLARE @GW_R_START_TIME INT;       -- 그룹웨어 시차 신청 출근 시간
    DECLARE @GW_R_CLOSE_TIME INT;       -- 그룹웨어 시차 신청 퇴근 시간
    DECLARE @C_NORMAL_TIME INT;         -- 선택근무제 인정 근무 시간 (분)
    DECLARE @C_AM INT;                  -- 선택근무제 오전 자율 근무 시간 (분) (09:00~10:00 사이 출근 시 인정되는 시간)
    DECLARE @C_CORE INT;                -- 선택근무제 코어 근무 시간 (분) (10:00~17:00)
    DECLARE @C_PM INT;                  -- 선택근무제 오후 자율 근무 시간 (분) (17:00~18:00 사이 퇴근 시 인정되는 시간)
    DECLARE @C_LATE_TIME INT;           -- 선택근무제 지각 시간 (분) (10:00 이후 출근)
    DECLARE @C_EARLY_TIME INT;          -- 선택근무제 조퇴 시간 (분) (17:00 이전 퇴근)
    DECLARE @C_PRIV_TIME INT;           -- 선택근무제 개인용무 시간 (시간 단위)
    DECLARE @C_REPVAC_TIME INT;         -- 선택근무제 대체휴가 시간 (시간 단위)
    DECLARE @C_BREAK_TIME INT;          -- 선택근무제 총 휴게 시간 (분)
    DECLARE @C_BREAK_TIME_12 INT;       -- 선택근무제 점심 휴게 시간 (분) (12:00~13:00)
    DECLARE @C_BREAK_TIME_18 INT;       -- 선택근무제 저녁 휴게 시간 (분) (18:00~, 조건부 발생)
    DECLARE @C_BREAK_TIME_01 INT;       -- 선택근무제 심야1 휴게 시간 (분) (01:00~02:00, 조건부 발생)
    DECLARE @C_BREAK_TIME_06 INT;       -- 선택근무제 심야2 휴게 시간 (분) (06:00~07:00, 조건부 발생)
    DECLARE @C_NIGHT_TIME INT;          -- 선택근무제 야간 시간 (분) (18:00~21:00)
    DECLARE @C_MIDNIGHT_TIME INT;       -- 선택근무제 심야 시간 (분) (21:00~24:00)
    DECLARE @C_ALLNIGHT_TIME INT;       -- 선택근무제 새벽 시간 (분) (00:00~07:00 또는 00:00~09:00, 그룹웨어 연동 시)

    DECLARE @C_ST_TIME INT;             -- 선택근무제 18시 휴게시간 계산용 조정 출근시간
    DECLARE @C_ET_TIME INT;             -- 선택근무제 18시 휴게시간 계산용 조정 퇴근시간

    DECLARE @C_HALF_TIME INT;           -- 반차 사용시 더해지는 시간 (분)
    DECLARE @C_HALF_HALF_TIME INT;      -- 반반차 사용시 더해지는 시간 (분)

	
	DECLARE @CHOICE_WORK VARCHAR(2)
	DECLARE @YESTERDAY VARCHAR(8)
	DECLARE @MISS_START INT
	DECLARE @MISS_CLOSE INT
	DECLARE @FIX_PERF VARCHAR(8)
	DECLARE @GET_PERF VARCHAR(8)
	DECLARE @C_ADD_TIME INT -- 선택근무 9시 이후 출근 시간 
	
	DECLARE @LUNCH_START INT
	DECLARE @LUNCH_END INT



    -- 프로시저 호출 시 전달된 값으로 대상 데이터 조회 및 변수 초기화
    BEGIN

        SELECT @DKID = DKID
				,@WORK_DT = WORK_DT
				,@PERF_CD = PERF_CD
				,@WORK_TYPE = WORK_TYPE
				,@START_TIME = CAST(START_TIME AS INT)
				,@CLOSE_TIME = CAST(CLOSE_TIME AS INT)
				,@C_START_TIME = CASE 
									WHEN GW_START_TIME IS NOT NULL AND GW_START_TIME > 0 
										THEN CAST(GW_START_TIME AS INT) 
									ELSE CAST(C_START_TIME AS INT) 
								 END
				,@C_CLOSE_TIME = CASE 
									WHEN GW_CLOSE_TIME IS NOT NULL AND GW_CLOSE_TIME > 0 
										THEN CAST(GW_CLOSE_TIME AS INT) 
									ELSE CAST(C_CLOSE_TIME AS INT) 
								 END
				,@GW_START_TIME    = CAST(GW_START_TIME    AS INT)
				,@GW_CLOSE_TIME    = CAST(GW_CLOSE_TIME    AS INT)
				,@GW_R_START_TIME  = CAST(GW_R_START_TIME  AS INT)
				,@GW_R_CLOSE_TIME  = CAST(GW_R_CLOSE_TIME  AS INT)
				,@LATE_TIME = 0
				,@EARLY_TIME = 0
				,@NORMAL_TIME = 0
				,@MIDNIGHT_TIME = 0
				,@NIGHT_TIME = 0
				,@ALLNIG_TIME = 0
				,@C_NORMAL_TIME = 0
				,@C_NIGHT_TIME = 0
				,@C_MIDNIGHT_TIME = 0
				,@C_ALLNIGHT_TIME = 0
				,@C_AM = 0
				,@C_PM = 0
				,@C_CORE = 0
				,@C_BREAK_TIME = 0
				,@C_BREAK_TIME_01 = 0
				,@C_BREAK_TIME_06 = 0
				,@C_BREAK_TIME_12 = 0
				,@C_BREAK_TIME_18 = 0
				,@C_PRIV_TIME = C_PRIV_TIME 
				,@C_REPVAC_TIME = C_REPVAC_TIME
				,@C_HALF_TIME = 0
				,@C_HALF_HALF_TIME = 0
				,@UP_OPID = UP_OPID
    FROM dbo.HR_TIMEATTENDANCE WITH (NOLOCK)
    WHERE EMP_ID = @P_EMP_ID AND WORK_DT = @P_WORK_DT;

	------------------------------------------------------------------
	-- [정규화] 0을 결측(NULL)로 간주: 과거 데이터/전처리에서 0이 들어온 경우 방지
	------------------------------------------------------------------
	SET @START_TIME     = NULLIF(@START_TIME,     0);
	SET @CLOSE_TIME     = NULLIF(@CLOSE_TIME,     0);
	SET @C_START_TIME   = NULLIF(@C_START_TIME,   0);
	SET @C_CLOSE_TIME   = NULLIF(@C_CLOSE_TIME,   0);
	SET @GW_START_TIME  = NULLIF(@GW_START_TIME,  0);
	SET @GW_CLOSE_TIME  = NULLIF(@GW_CLOSE_TIME,  0);
	SET @GW_R_START_TIME= NULLIF(@GW_R_START_TIME,0);
	SET @GW_R_CLOSE_TIME= NULLIF(@GW_R_CLOSE_TIME,0);

	-- 시작/종료 중 하나라도 없으면 이후 기본근무 계산 블록들이 실행되지 않도록 함
	-- (아래 BASIC_CALC/CHOICE_CALC 내 조건은 IS NULL 체크로 충분)


    -- 대상 데이터가 없는 경우 프로시저 종료
    IF @DKID IS NULL
    BEGIN
        -- -- -- --print '== USP_CALCULATE_TIMEATTENDANCE: 처리할 데이터가 없습니다. DKID=' + ISNULL(CAST(@P_EMP_ID AS VARCHAR), 'NULL') + ', WORK_DT=' + ISNULL(@P_WORK_DT, 'NULL') + ' ==';
        RETURN;
    END
	
			-- -- --print '== HR_TIMEATTENDANCE 트리거 시작 =='
			-- -- --print '@DKID : ' + CAST(@DKID AS VARCHAR)
			-- -- --print '@START_TIME : ' + CAST(@START_TIME AS VARCHAR)
			-- -- --print '@CLOSE_TIME : ' + CAST(@CLOSE_TIME AS VARCHAR)
			-- -- --print '@C_START_TIME : ' + CAST(@C_START_TIME AS VARCHAR)
			-- -- --print '@C_CLOSE_TIME : ' + CAST(@C_CLOSE_TIME AS VARCHAR)
			-- -- --print '@WORK_TYPE : ' + CAST(@WORK_TYPE AS VARCHAR)
			-- -- --print '@PERF_CD : ' + CAST(@PERF_CD AS VARCHAR)
			-- -- --print '@WORK_DT : ' + CAST(@WORK_DT AS VARCHAR)
			--IF (@START_TIME != 0) AND (@CLOSE_TIME != 0)
			-- -- --print '@UP_OPID : ' + CAST(@UP_OPID AS VARCHAR)

			/*
			2024-03-28 누락 체크 해제
			UPDATE_TIMEATTENDANCE_MISSED 프로시저에서 선택근무시간제 근태 누락 처리 전일 출근/최근 모두 없을 경우 누락처리하면서 SYSTEM3으로 업데이트 함.
			SYSTEM3 상태 체크 제외함.
			
			IF (@UP_OPID = 'SYSTEM3')
				BEGIN
					RETURN
				END
			*/

	
		DECLARE @SHIFT_MIN INT = CASE @PERF_CD
                    WHEN 'G52' THEN  60 WHEN 'G53' THEN 120 WHEN 'G54' THEN 180
                    WHEN 'G55' THEN 240 WHEN 'G56' THEN 300 WHEN 'G57' THEN 360
                    WHEN 'G58' THEN 420 ELSE 0 END;

		SET @CHOICE_WORK = 'Y' --CASE WHEN ISNULL(@C_START_TIME,0) != 0 OR ISNULL(@C_CLOSE_TIME,0) != 0 THEN 'Y' ELSE 'N' END
		--SET @CHOICE_WORK = CASE WHEN ISNULL(@START_TIME,0) != 0 AND ISNULL(@CLOSE_TIME,0) != 0 THEN 'N' ELSE 'Y' END

		--PRINT '선택근무 여부 : ' + @CHOICE_WORK

		SET @YESTERDAY = (SELECT MAX(WORK_DT) FROM HR_TIMEATTENDANCE WITH (NOLOCK) 
							WHERE DKID = @DKID  AND WORK_DT < @WORK_DT AND WORK_TYPE = 'W' AND PERF_CD IN ('G01','G42') )

		--전체 공란 처리.
		IF @PERF_CD = 'NONE'
			BEGIN
				GOTO PERF_NONE
			END

		--공가 처리.
		IF @PERF_CD = 'G51'
			BEGIN
					
				GOTO PERF_G51
			END
			
		--출장 처리.
		IF @PERF_CD = 'G15' 
			BEGIN
				SET @FIX_PERF = 'G15'
				GOTO PERF_G15
			END
				

		-- 입력된 날짜의 근태상태가 "출근누락","퇴근누락","누락"근태일 경우 근태를 "출근"으로 반영. 입력된 자료로 시간계산
		IF (@PERF_CD = 'G37' OR @PERF_CD = 'G38') OR @PERF_CD = 'G39'
			BEGIN
				----print '입력된 날짜의 근태상태가 "출근누락","퇴근누락","누락'
				GOTO SET_G01
			END

		-- 누락 체크를 위한 출퇴근 시간 찾기
			IF @CHOICE_WORK = 'Y'
				BEGIN
					--print '선택근무 누락 시간'
					SELECT @MISS_START = C_START_TIME, @MISS_CLOSE = C_CLOSE_TIME  FROM HR_TIMEATTENDANCE WITH (NOLOCK)
							WHERE DKID = @DKID  AND WORK_DT = @YESTERDAY	

							print CONCAT('@MISS_START : ' , @MISS_START , '@MISS_CLOSE : ' , @MISS_CLOSE)

							GOTO CHOICE_CALC
				END
			ELSE
				BEGIN
					--print '일반근무 누락 시간'
					SELECT @MISS_START = START_TIME, @MISS_CLOSE = CLOSE_TIME  FROM HR_TIMEATTENDANCE WITH (NOLOCK)
							WHERE DKID = @DKID  AND WORK_DT = @YESTERDAY	
							
							----print CONCAT('@MISS_START : ' , @MISS_START , '@MISS_CLOSE : ' , @MISS_CLOSE)

							GOTO BASIC_CALC
				END


			BASIC_CALC:
				print 'basic_clac'

				BEGIN
					-- 지각, 조퇴, 연장, 야간, 심야시간 계산
					IF (@PERF_CD ='G01' OR @PERF_CD ='G02')
						BEGIN
							IF  (543 < @START_TIME) AND (@WORK_TYPE = 'W')
								BEGIN
									-- --print '지각시간 계산'
									IF ( (720 <= @START_TIME) AND (@START_TIME <= 780) )
										BEGIN
											SELECT @LATE_TIME = 180
										END
									ELSE IF 780 < @START_TIME 
										BEGIN
											SELECT @LATE_TIME = @START_TIME - 600 --ROUND((@START_TIME - 600)/60,0,1) + ((@START_TIME - 600)%60)/CAST(100 AS FLOAT)
										END
									ELSE
										BEGIN
											SELECT @LATE_TIME = @START_TIME - 540 --ROUND((@START_TIME - 540)/60,0,1) + ((@START_TIME - 540)%60)/CAST(100 AS FLOAT)
										END

									-- --print '@LATE_TIME : ' + CAST(@LATE_TIME AS VARCHAR)
								END			
						END	

					IF (@START_TIME IS NOT NULL) AND (@CLOSE_TIME IS NOT NULL)
						BEGIN
						--조퇴시간 계산
						--시차휴가 추가 keonhuilee
						IF ( (540 < @CLOSE_TIME) AND (@CLOSE_TIME < 1080) ) AND (@PERF_CD NOT IN ('G04','G40','G41','G45','G46','G47','G50','G52','G53','G54','G55','G56','G57','G58'))
							BEGIN

								SELECT @EARLY_TIME = 1080 - @CLOSE_TIME -- ROUND((1080 - @CLOSE_TIME)/60,0,1) + ((1080 - @CLOSE_TIME)%60)/CAST(100 AS FLOAT)					
						
								-- --print '@EARLY_TIME : ' + CAST(@EARLY_TIME AS VARCHAR)
							END					
				
						--연장시간 계산  ALLNIG_TIME
						IF ( (1080 < @CLOSE_TIME) AND (@CLOSE_TIME <= 1260) )
							BEGIN
								SELECT @ALLNIG_TIME = @CLOSE_TIME - 1080 --ROUND((@CLOSE_TIME - 1080)/60,0,1) + ((@CLOSE_TIME - 1080)%60)/CAST(100 AS FLOAT)
								-- --print '@ALLNIG_TIME : ' + CAST(@ALLNIG_TIME AS VARCHAR)
							END

						--야간시간 계산  NIGHT_TIME
						ELSE IF ( (1260 < @CLOSE_TIME) AND (@CLOSE_TIME <= 1440) )
							BEGIN					
								SELECT @ALLNIG_TIME = 180
									,@NIGHT_TIME = @CLOSE_TIME - 1260 --ROUND((@CLOSE_TIME - 1260)/60,0,1) + ((@CLOSE_TIME - 1260)%60)/CAST(100 AS FLOAT)
								-- --print '@NIGHT_TIME : ' + CAST(@NIGHT_TIME AS VARCHAR)						
							END
				

						--심야시간 계산 MIDNIGHT_TIME
						ELSE IF ( (0 < @CLOSE_TIME) AND (@CLOSE_TIME <= 240) )
							BEGIN
								SELECT @ALLNIG_TIME = 180
									,@NIGHT_TIME = 180
									,@MIDNIGHT_TIME = @CLOSE_TIME --ROUND((@CLOSE_TIME)/60,0,1) + ((@CLOSE_TIME)%60)/CAST(100 AS FLOAT)
								-- --print '@MIDNIGHT_TIME : ' + CAST(@MIDNIGHT_TIME AS VARCHAR)
							END
						END
				
						
				--지각시간 반영하여 시간 조정
				
				IF @WORK_TYPE = 'W'
					BEGIN
						IF ( (480 <= @LATE_TIME) AND (@LATE_TIME < 660) )
							BEGIN
								-- --print 'CALC 1'
								SELECT @ALLNIG_TIME = @ALLNIG_TIME -(@LATE_TIME - 480)
							END
						ELSE IF ( (660 <= @LATE_TIME) AND (@LATE_TIME < 840) )
							BEGIN
								-- --print 'CALC 2'
								SELECT @ALLNIG_TIME = @ALLNIG_TIME -(@LATE_TIME - 660)
							END
					END
				

				--휴일반영 / 정상시간계산
				
					-- --print '휴일반영 / 정상시간계산'
					 --print '@START_TIME : ' + CAST(@START_TIME AS VARCHAR)
					 --print '@CLOSE_TIME : ' + CAST(@CLOSE_TIME AS VARCHAR)
					IF (@START_TIME IS NOT NULL) AND (@CLOSE_TIME IS NOT NULL)		
						-- --print '정상시간계산'
						BEGIN
							IF @WORK_TYPE = 'H'
								BEGIN
									-- --print '휴일(WORK_TYPE : '+ CAST(@WORK_TYPE AS VARCHAR)+')'

									SELECT @NORMAL_TIME = CASE WHEN (@CLOSE_TIME < 1080) AND (@START_TIME < @CLOSE_TIME) THEN @CLOSE_TIME - @START_TIME ELSE 1080 - @START_TIME END
									,@ALLNIG_TIME = @NORMAL_TIME + @ALLNIG_TIME + @NIGHT_TIME 
									,@LATE_TIME = 0
									,@EARLY_TIME = 0
									,@NIGHT_TIME = 0
									,@NORMAL_TIME = 0

									 --print '@NORMAL_TIME : ' + CAST(@NORMAL_TIME AS VARCHAR)
									 --print '@ALLNIG_TIME : ' + CAST(@ALLNIG_TIME AS VARCHAR)
									 --print '@NIGHT_TIME : ' + CAST(@NIGHT_TIME AS VARCHAR)

								END
							ELSE
								BEGIN
									-- --print '평일(WORK_TYPE : '+ CAST(@WORK_TYPE AS VARCHAR)+')'
									IF (@PERF_CD IN ('G40', 'G41', 'G45'))
										BEGIN
											-- --print '평일1'
											SELECT @NORMAL_TIME = 480 - @LATE_TIME - @EARLY_TIME - 240
											-- --print '평일1_(' + CAST(@NORMAL_TIME AS VARCHAR) + ')'
										END
									-- 시차휴가 추가 keonhuilee
									ELSE IF (@PERF_CD IN ('G52', 'G53', 'G54', 'G55', 'G56', 'G57', 'G58'))
										BEGIN
											-- 기존: 480 - 지각 - 조퇴 - (시차분)  
											-- 변경: (근무가능 480 - 지각 - 조퇴) + 시차분, 8시간 상한 
											SET @NORMAL_TIME = 
												CASE 
												  WHEN @WORK_TYPE = 'W'
													THEN 
													  CASE 
														WHEN (480 - ISNULL(@LATE_TIME,0) - ISNULL(@EARLY_TIME,0)) < 0 
															THEN 0
														ELSE 
															CASE 
															  WHEN (480 - ISNULL(@LATE_TIME,0) - ISNULL(@EARLY_TIME,0) + @SHIFT_MIN) > 480 
																   THEN 480
															  ELSE (480 - ISNULL(@LATE_TIME,0) - ISNULL(@EARLY_TIME,0) + @SHIFT_MIN)
															END
													  END
												  ELSE @NORMAL_TIME
												END;
										END
									ELSE
										BEGIN
											-- --print '평일2'
											IF (@CLOSE_TIME IS NULL OR @START_TIME IS NULL)
												BEGIN
													SELECT @NORMAL_TIME = 0
												END
                                             ELSE IF (@CLOSE_TIME - @START_TIME = 0)
                                                 BEGIN
                                                     SELECT @NORMAL_TIME = 0
												END
											ELSE
												BEGIN
													SELECT @NORMAL_TIME = 480 - @LATE_TIME - @EARLY_TIME
												END
											-- --print '평일2_(' + CAST(@NORMAL_TIME AS VARCHAR) + ')'
										END
											
								END
								BEGIN
									--반반차/ 대체휴가 반영
								
									SELECT @NORMAL_TIME = CASE WHEN @PERF_CD = 'G47' THEN @NORMAL_TIME - 120 ELSE @NORMAL_TIME END 
									-- --print '반반차(G47) 반영 @NORMAL_TIME : ' + CAST(@NORMAL_TIME AS VARCHAR)
									-- --print '대체휴가 @C_REPVAC_TIME : ' + CAST(@C_REPVAC_TIME*60 AS VARCHAR)
