									BEGIN
										-- 추가된 로직
										SET @C_NORMAL_TIME = 0
									END
								ELSE
									BEGIN
										--print '반영(기존로직)'
										-- 반영(기존로직)
										UPDATE HR_TIMEATTENDANCE
											SET C_NORMAL_TIME = IIF(@C_NORMAL_TIME < 0, 0, @C_NORMAL_TIME)
											,C_NIGHT_TIME = @C_NIGHT_TIME
											,C_MIDNIGHT_TIME = @C_MIDNIGHT_TIME
											,C_ALLNIGHT_TIME = @C_ALLNIGHT_TIME
											,C_BREAK_TIME = @C_BREAK_TIME						
											,C_LATE_TIME = @C_LATE_TIME
											,C_EARLY_TIME = @C_EARLY_TIME
											,UP_DATETIME = GETDATE()
											,UP_OPID = 'SYSTEM'
										WHERE DKID = @DKID
										AND WORK_DT = @WORK_DT
									END
							END
						
						
						ELSE 
							BEGIN
								-- 휴일(휴일관련 로직변경 : 2018.07.16)
								-- 기존 로직에서 24시 이후 퇴근할 경우 계산하는 로직 추가(ELSE 이하 부분)(2018.07.16)
								-- 추가변경 ( 2018.09.27 김문성 요청 )
								-- 추가변경1 : 그룹웨어에서 신청내역이 들어올 경우 휴일 근무에 대해서 시간을 계산함
								-- 추가변경2 : 휴일근무 시간(그룹웨어에서 신청한 시작시간, 마감시간)을 가져와서 시간을 계산함
								--print '== 휴일 시간 계산 시작 =='
								--print '@C_START_TIME(@GW_START_TIME) : ' + CAST(@C_START_TIME AS VARCHAR) + '(' + RTRIM(CAST(@GW_START_TIME AS VARCHAR)) + ')'
								--print '@C_CLOSE_TIME(@GW_CLOSE_TIME) : ' + CAST(@C_CLOSE_TIME AS VARCHAR) + '(' + RTRIM(CAST(@GW_CLOSE_TIME AS VARCHAR)) + ')'
								IF @GW_CLOSE_TIME IS NOT NULL AND @GW_CLOSE_TIME > 0
									BEGIN
										SELECT @C_CLOSE_TIME = @GW_CLOSE_TIME
										--print '퇴근시간(그룹웨어 퇴근시간) : ' + CAST(@C_CLOSE_TIME AS VARCHAR) + '(' + RTRIM(CAST(@GW_CLOSE_TIME AS VARCHAR)) + ')'
										IF (@C_START_TIME IS NOT NULL AND @C_CLOSE_TIME IS NOT NULL) 
											BEGIN
