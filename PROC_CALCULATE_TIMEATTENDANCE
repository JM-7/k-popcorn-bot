															END
						
														
														SELECT @C_NORMAL_TIME = (@C_CLOSE_TIME - @C_START_TIME) - @C_BREAK_TIME
						
													END
						

												-- 반영
												UPDATE HR_TIMEATTENDANCE
												SET C_NORMAL_TIME = IIF(@C_NORMAL_TIME < 0, 0, @C_NORMAL_TIME)
													,C_BREAK_TIME = @C_BREAK_TIME						
													,UP_DATETIME = GETDATE()
													,UP_OPID = 'SYSTEM'
												WHERE DKID = @DKID
												AND WORK_DT = @WORK_DT
											END
									END
							END

						--출근누락 계산 “출근누락”, 출근시간 10시고정하고 시간계산
